<%- include('partials/header') %>

<% const blogPosts = posts || [] %>
<% const defaultPost = blogPosts[blogPosts.length - 1] %>
<% const defaultPostId = defaultPost ? defaultPost.id : '' %>

<section class="blog-hero">
	<div class="container">
		<span class="blog-kicker"><%= t('blog.title') %></span>
		<h1><%= t('blog.pageTitle') %></h1>
		<p><%= t('blog.introduction') %></p>
	</div>
</section>

<section class="blog-shell">
	<div class="container blog-layout">
		<aside class="blog-sidebar" aria-label="Blog navigation">
			<div class="blog-sidebar-card">
				<p class="blog-sidebar-label">Table of contents</p>
				<nav class="blog-toc">
					<% blogPosts.forEach(post => { %>
						<a
							href="#<%= post.id %>"
							data-post-link="<%= post.id %>"
							class="<%= defaultPost && defaultPost.id === post.id ? 'is-active' : '' %>"
							aria-current="<%= defaultPost && defaultPost.id === post.id ? 'true' : 'false' %>"
						><%= post.title %></a>
					<% }); %>
				</nav>
			</div>
		</aside>

		<div class="blog-content" aria-label="Blog posts" data-blog-content data-default-post="<%= defaultPostId %>">
			<% blogPosts.forEach(post => { %>
				<article
					class="blog-post <%= defaultPost && defaultPost.id === post.id ? 'is-active' : '' %>"
					id="<%= post.id %>"
					data-blog-post="<%= post.id %>"
					<%- defaultPost && defaultPost.id === post.id ? '' : 'hidden' %>
				>
					<div class="blog-post-header">
						<span class="blog-post-eyebrow"><%= post.eyebrow %></span>
						<div class="blog-post-meta">
							<span><%= post.date %></span>
							<span><%= post.readTime %></span>
						</div>
						<h2><%= post.title %></h2>
						<p><%= post.summary %></p>
					</div>
					
					
						<section class ="blog-post-section">
							<%- post.body %>
						</section>
					
				</article>
			<% }); %>
		</div>
	</div>
</section>
<script src="/blog.js"></script>

<%- include('partials/footer') %>
