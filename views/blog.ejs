<section class="blog-hero">
	<div class="container">
		<span class="blog-kicker"><%= t('blog.title') %></span>
		<h1><%= t('blog.metaDescription') %></h1>
		<p><%= t('blog.introduction') %></p>
	</div>
</section>

<section class="blog-shell">
	<div class="container blog-layout">
		<aside class="blog-sidebar" aria-label="Blog navigation">
			<div class="blog-sidebar-card">
				<p class="blog-sidebar-label">Table of contents</p>
				<nav class="blog-toc">
					<% blogPosts.forEach(post => { %>
						<a href="#<%= post.id %>"><%= post.title %></a>
					<% }); %>
				</nav>
			</div>

			<div class="blog-sidebar-card">
				<p class="blog-sidebar-label">Blog posts</p>
				<div class="blog-post-list">
					<% blogPosts.forEach(post => { %>
						<a class="blog-post-link" href="#<%= post.id %>">
							<span class="blog-post-link-meta"><%= post.eyebrow %> · <%= post.readTime %></span>
							<strong><%= post.title %></strong>
							<span><%= post.summary %></span>
						</a>
					<% }); %>
				</div>
			</div>
		</aside>

		<div class="blog-content" aria-label="Blog posts">
			<% blogPosts.forEach(post => { %>
				<article class="blog-post" id="<%= post.id %>">
					<div class="blog-post-header">
						<span class="blog-post-eyebrow"><%= post.eyebrow %></span>
						<div class="blog-post-meta">
							<span><%= post.date %></span>
							<span><%= post.readTime %></span>
						</div>
						<h2><%= post.title %></h2>
						<p><%= post.summary %></p>
					</div>
					
					<div class="blog-post-body">
						<section class ="blog-post-section">
							<%- post.body %>
						</section>
					</div>
				</article>
			<% }); %>
		</div>
	</div>
</section>

<%- include('partials/footer') %>
