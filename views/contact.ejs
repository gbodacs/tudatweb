<%- include('partials/header') %>

<section class="blog-hero">
	<div class="container">
    <span class="blog-kicker"><%= t('contact.title') %></span>
		<h1><%= t('contact.pageTitle') %></h1>
    <p><%= t('contact.introduction') %></p>
	</div>
</section>

<main class="container contact-page">
  <div class="features">
    <h2><%= t('contact.faqheader') %></h2>
    <br/><h3><%= t('contact.faqQuestion1') %></h3>
    <ul>
      <li><%= t('contact.faqAnswer1') %></li>
    </ul>
    <br/><h3><%= t('contact.faqQuestion2') %></h3>
    <ul>
      <li><%= t('contact.faqAnswer2') %></li>
    </ul>
    <br/><h3><%= t('contact.faqQuestion3') %></h3>
    <ul>
      <li><%= t('contact.faqAnswer3') %></li>
    </ul>
  </div>

  <br/><br/>
    <% if (success) { %>
      <p style="color: green;"><%= t('contact.successMessage') %></p>
      </br>
    <% } %>
    <% if (error) { %>
      <p style="color: red;"><%= error %></p>
      </br>
    <% } %>

    <div class="contact-grid">
      <div class="contact-card">
        <h2><%= t('contact.contactDetails') %></h2>
        <p><strong><%= t('contact.emailLabel') %></strong> <%= t('contact.emailValue') %></p>
      </div>

      <div class="contact-card">
        <h2><%= t('contact.messageForm') %></h2>
        <form action="/contact" method="post" class="contact-form">
          <label for="name"><%= t('contact.nameLabel') %></label>
          <input type="text" id="name" name="name" placeholder="<%= t('contact.namePlaceholder') %>" required />

          <label for="email"><%= t('contact.emailFormLabel') %></label>
          <input type="email" id="email" name="email" placeholder="<%= t('contact.emailPlaceholder') %>" required />

          <label for="message"><%= t('contact.messageLabel') %></label>
          <textarea id="message" name="message" rows="6" placeholder="<%= t('contact.messagePlaceholder') %>" required></textarea>

          <button type="submit" class="btn"><%= t('contact.submitButton') %></button>
        </form>
      </div>
    </div>
  </main>
  </br>
  </br>
<%- include('partials/footer') %>