<%- include('partials/header') %>

  <main class="container contact-page">
    <h1>Kapcsolat</h1>
    <p>Vegye fel velünk a kapcsolatot és építsük együtt az automatizált digitális jövőt.</p>
    </br>
    <% if (success) { %>
      <p style="color: green;">Köszönjük az üzenetet! Hamarosan felvesszük Önnel a kapcsolatot.</p>
      </br>
    <% } %>
    <% if (error) { %>
      <p style="color: red;"><%= error %></p>
      </br>
    <% } %>

    <div class="contact-grid">
      <div class="contact-card">
        <h2>Elérhetőségeink</h2>
        <p><strong>Email:</strong> tudatai@protonmail.com</p>
      </div>

      <div class="contact-card">
        <h2>Üzenet küldése</h2>
        <form action="/contact" method="post" class="contact-form">
          <label for="name">Név</label>
          <input type="text" id="name" name="name" placeholder="Teljes név" required />

          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="email@pelda.hu" required />

          <label for="message">Üzenet (200 karakter)</label>
          <textarea id="message" name="message" rows="6" placeholder="Miben segíthetünk?" required></textarea>

          <button type="submit" class="btn">Küldés</button>
        </form>
      </div>
    </div>
  </main>
  </br>
  </br>
<%- include('partials/footer') %>